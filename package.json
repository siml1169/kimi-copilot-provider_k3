{
  "name": "kimi3-copilot-provider",
  "displayName": "Kimi3 Copilot Provider",
  "description": "Use Kimi K2, K2.7, and K3 models as a custom language model provider for GitHub Copilot Chat (fork with K3 support)",
  "version": "1.5.1",
  "publisher": "Webboy998",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/siml1169/kimi-copilot-provider_k3.git"
  },
  "bugs": {
    "url": "https://github.com/siml1169/kimi-copilot-provider_k3/issues"
  },
  "homepage": "https://github.com/siml1169/kimi-copilot-provider_k3#readme",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [
    "onLanguageModelChatProvider:kimi3-copilot"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "kimi3-copilot",
        "displayName": "Kimi3 Copilot Provider",
        "managementCommand": "kimi3-copilot.openSettings"
      }
    ],
    "commands": [
      {
        "command": "kimi3-copilot.setApiKey",
        "title": "Set API Key",
        "category": "Kimi3 Copilot"
      },
      {
        "command": "kimi3-copilot.setK3ApiKey",
        "title": "Set K3 API Key",
        "category": "Kimi3 Copilot"
      },
      {
        "command": "kimi3-copilot.selectModel",
        "title": "Select Default Model",
        "category": "Kimi3 Copilot"
      },
      {
        "command": "kimi3-copilot.editModelConfig",
        "title": "Edit Model Configuration",
        "category": "Kimi3 Copilot"
      },
      {
        "command": "kimi3-copilot.testConnection",
        "title": "Test Connection",
        "category": "Kimi3 Copilot"
      },
      {
        "command": "kimi3-copilot.openSettings",
        "title": "Open Settings",
        "category": "Kimi3 Copilot"
      },
      {
        "command": "kimi3-copilot.showUsageStats",
        "title": "Show Usage Stats",
        "category": "Kimi3 Copilot"
      },
      {
        "command": "kimi3-copilot.resetUsageStats",
        "title": "Reset Usage Stats",
        "category": "Kimi3 Copilot"
      }
    ],
    "configuration": {
      "title": "Kimi3 Copilot",
      "properties": {
        "kimi3Copilot.baseUrl": {
          "type": "string",
          "default": "https://api.moonshot.ai",
          "description": "Base URL for the Kimi API (Moonshot). Change for self-hosted or proxied deployments."
        },
        "kimi3Copilot.endpoint": {
          "type": "string",
          "default": "https://api.moonshot.ai/v1/chat/completions",
          "description": "Full Kimi API endpoint URL. Overrides baseUrl when set to a non-default value."
        },
        "kimi3Copilot.k3Endpoint": {
          "type": "string",
          "default": "",
          "description": "Override endpoint for K3 models only. Leave empty to use the main endpoint."
        },
        "kimi3Copilot.modelIdOverrides": {
          "type": "object",
          "default": {},
          "description": "Override API model IDs sent for each picker model. Example: { \"kimi-for-coding\": \"your-custom-model-id\" }"
        },
        "kimi3Copilot.model": {
          "type": "string",
          "default": "kimi-k2.7-code",
          "description": "Default Kimi model ID used in chat. Use 'kimi-k2.7-code', 'kimi-k2.7-code-highspeed', 'kimi-k2.6', 'kimi-k2.5', or 'kimi-k3'."
        },
        "kimi3Copilot.modelConfigs": {
          "type": [
            "object",
            "null"
          ],
          "default": {},
          "description": "Per-model overrides. Key is the picker model ID. Example: { \"kimi-k2.7-code\": { maxInputTokens: 256000, maxOutputTokens: 32768, temperature: 1.0, topP: 0.95, thinking: { type: \"enabled\" }, systemPrompt: \"...\" } }.",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "overrideModelId": {
                "type": "string",
                "description": "Override API model ID sent for this picker model."
              },
              "maxInputTokens": {
                "type": "number",
                "minimum": 1,
                "description": "Max input tokens reported to Copilot Chat for this model."
              },
              "maxOutputTokens": {
                "type": "number",
                "minimum": 1,
                "description": "Max output tokens for this model."
              },
              "temperature": {
                "type": "number",
                "minimum": 0,
                "maximum": 2,
                "description": "Sampling temperature for this model."
              },
              "topP": {
                "type": "number",
                "minimum": 0,
                "maximum": 1,
                "description": "Top-p sampling for this model."
              },
              "presencePenalty": {
                "type": "number",
                "minimum": -2,
                "maximum": 2,
                "description": "Presence penalty for this model."
              },
              "frequencyPenalty": {
                "type": "number",
                "minimum": -2,
                "maximum": 2,
                "description": "Frequency penalty for this model."
              },
              "thinking": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": [
                      "enabled",
                      "disabled"
                    ],
                    "description": "Thinking mode. Kimi K2.7 requires enabled."
                  }
                },
                "required": [
                  "type"
                ]
              },
              "systemPrompt": {
                "type": "string",
                "description": "System prompt used for this model."
              },
              "toolCalling": {
                "type": "boolean",
                "description": "Enable tool calling for this model."
              }
            },
            "additionalProperties": false
          }
        },
        "kimi3Copilot.temperature": {
          "type": "number",
          "default": 1,
          "minimum": 0,
          "maximum": 2,
          "description": "Sampling temperature for generation (0–2). Per-model value in modelConfigs takes precedence."
        },
        "kimi3Copilot.maxTokens": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 32768,
          "description": "Maximum output tokens. Set to 0 for model default. Per-model value in modelConfigs takes precedence."
        },
        "kimi3Copilot.topP": {
          "type": "number",
          "default": 0.95,
          "minimum": 0,
          "maximum": 1,
          "description": "Top-p (nucleus) sampling. Model-dependent; K2.7 defaults to 0.95."
        },
        "kimi3Copilot.presencePenalty": {
          "type": "number",
          "default": 0,
          "minimum": -2,
          "maximum": 2,
          "description": "Presence penalty for new tokens (model-dependent)."
        },
        "kimi3Copilot.frequencyPenalty": {
          "type": "number",
          "default": 0,
          "minimum": -2,
          "maximum": 2,
          "description": "Frequency penalty for repeated tokens (model-dependent)."
        },
        "kimi3Copilot.timeout": {
          "type": "number",
          "default": 60000,
          "minimum": 1000,
          "description": "Request timeout in milliseconds."
        },
        "kimi3Copilot.enableStreaming": {
          "type": "boolean",
          "default": true,
          "description": "Enable SSE streaming responses."
        },
        "kimi3Copilot.systemPrompt": {
          "type": "string",
          "default": "You are Kimi, an AI assistant provided by Moonshot AI. You are proficient in Chinese and English conversations. You provide users with safe, helpful, and accurate answers. You will reject any questions involving terrorism, racism, or explicit content. Moonshot AI is a proper noun and should not be translated.",
          "description": "System prompt sent with every request. Can be overridden per model in modelConfigs."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src",
    "format": "prettier --write src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.93.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "sharp": "^0.35.3",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0"
  }
}
